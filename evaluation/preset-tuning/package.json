{
  "name": "preset-tuning",
  "version": "1.0.0",
  "description": "Finds the optimal preset parameters for gpt-oss:120b-cloud by benchmarking 16 candidate configurations.",
  "private": true,
  "scripts": {
    "tune":          "ts-node run.ts",
    "tune:quick":    "ts-node run.ts --profiles quick",
    "tune:strict":   "ts-node run.ts --profiles strict",
    "tune:balanced": "ts-node run.ts --profiles balanced",
    "tune:thorough": "ts-node run.ts --profiles thorough",
    "tune:fast":     "ts-node run.ts --fixtures html-issues,tsx-issues,css-issues,js-issues",
    "tune:runs2":    "ts-node run.ts --runs 2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
