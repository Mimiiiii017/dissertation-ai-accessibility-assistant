{
  "name": "cloud-llm-preliminary",
  "version": "1.0.0",
  "description": "Benchmarks installed LLM models to find the best fit: fewest mistakes, fastest, most thorough.",
  "private": true,
  "scripts": {
    "smoke":                "ts-node smoke-test.ts",
    "validate":             "ts-node validate-ground-truth.ts",
    "bench":                "ts-node run.ts",
    "bench:html":           "ts-node run.ts --lang html",
    "bench:css":            "ts-node run.ts --lang css",
    "bench:js":             "ts-node run.ts --lang js",
    "bench:tsx":            "ts-node run.ts --lang tsx",
    "bench:adversarial":    "ts-node run.ts --adversarial",
    "study:rag-think":      "ts-node run.ts --lang html",
    "study:rag-nothink":    "ts-node run.ts --lang html --no-think",
    "study:norag-think":    "ts-node run.ts --lang html --no-rag",
    "study:norag-nothink":  "ts-node run.ts --lang html --no-rag --no-think"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}