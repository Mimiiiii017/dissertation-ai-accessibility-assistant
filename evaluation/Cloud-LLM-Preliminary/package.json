{
  "name": "cloud-llm-preliminary",
  "version": "1.0.0",
  "description": "Benchmarks installed LLM models to find the best fit: fewest mistakes, fastest, most thorough.",
  "private": true,
  "scripts": {
    "bench":           "ts-node run.ts",
    "bench:fast":      "ts-node run.ts --fixtures html-issues,tsx-issues,css-issues,js-issues",
    "bench:clean":     "ts-node run.ts --fixtures html-clean,tsx-clean,css-clean,js-clean",
    "bench:runs2":     "ts-node run.ts --runs 2",
    "smoke":           "ts-node smoke-test.ts",
    "validate":        "ts-node validate-ground-truth.ts",
    "gen-adversarial": "ts-node generate-adversarial-fixtures.ts",
    "full-bench":      "ts-node validate-ground-truth.ts && ts-node run.ts",
    "full-bench:html": "ts-node validate-ground-truth.ts && ts-node run.ts --lang html",
    "full-bench:css":  "ts-node validate-ground-truth.ts && ts-node run.ts --lang css",
    "full-bench:js":   "ts-node validate-ground-truth.ts && ts-node run.ts --lang js",
    "full-bench:tsx":  "ts-node validate-ground-truth.ts && ts-node run.ts --lang tsx"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
