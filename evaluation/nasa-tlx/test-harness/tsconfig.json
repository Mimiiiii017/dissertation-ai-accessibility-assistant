{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "../../benchmark/benchmark.ts",
    "../../benchmark/benchmark-params.ts",
    "../../benchmark/benchmark-prompt.ts",
    "../../fixtures/ground-truth.ts",
    "../../fixtures/benchmark.ts",
    "../../../extension/ai-accessibility-assistant/src/utils/llm/ollama.ts",
    "../../../extension/ai-accessibility-assistant/src/utils/analysis/parser.ts",
    "../../../extension/ai-accessibility-assistant/src/utils/types.ts",
    "../../../extension/ai-accessibility-assistant/src/utils/rag/rag.ts",
    "../../../extension/ai-accessibility-assistant/src/utils/rag/ragQueryBuilder.ts"
  ],
  "exclude": ["node_modules"]
}
