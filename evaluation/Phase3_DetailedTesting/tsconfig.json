{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "lib": ["ES2022"],
    "skipLibCheck": true
  },
  "include": [
    "*.ts",
    "../benchmark/benchmark.ts",
    "../benchmark/benchmark-params.ts",
    "../benchmark/benchmark-prompt.ts",
    "../fixtures/ground-truth.ts",
    "../fixtures/benchmark.ts",
    "../../extension/ai-accessibility-assistant/src/utils/llm/ollama.ts",
    "../../extension/ai-accessibility-assistant/src/utils/prompts/prompt.ts",
    "../../extension/ai-accessibility-assistant/src/utils/analysis/parser.ts",
    "../../extension/ai-accessibility-assistant/src/utils/types.ts"
  ],
  "exclude": ["node_modules", "dist", "results"]
}
